# MemWal (Walrus Memory)
# The Python backend no longer writes to MemWal; only frontend env vars are required.
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# Frontend MemWal (each wallet owns its own MemWalAccount; users pay gas to create it and authorize a delegate key)
VITE_MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
VITE_MEMWAL_PACKAGE_ID=0xcee7a6fd8de52ce645c38332bde23d4a30fd9426bc4681409733dd50958a24c6
VITE_MEMWAL_REGISTRY_ID=0x0da982cefa26864ae834a8a0504b904233d49e20fcc17c373c8bed99c75a7edd

# Supabase (backend uses the service key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Groq (LLM)
GROQ_API_KEY=

# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

VITE_GOOGLE_CLIENT_ID=

# Sui network: mainnet | testnet | devnet (defaults to testnet)
VITE_SUI_NETWORK=testnet
